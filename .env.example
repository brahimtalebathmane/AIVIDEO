# SiliconFlow API key — get yours at https://cloud.siliconflow.com/account/ak
SILICONFLOW_API_KEY=your_api_key_here

# Optional model overrides (quality tier uses Wan2.2; Fast preset uses Turbo)
# SILICONFLOW_VIDEO_MODEL=Wan-AI/Wan2.2-T2V-A14B
# SILICONFLOW_I2V_MODEL=Wan-AI/Wan2.2-I2V-A14B
# Fast preset (720P — lighter than Wan2.2)
# SILICONFLOW_FAST_T2V_MODEL=Wan-AI/Wan2.1-T2V-14B-720P
# SILICONFLOW_FAST_I2V_MODEL=Wan-AI/Wan2.1-I2V-14B-720P
